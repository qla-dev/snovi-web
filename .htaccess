RewriteEngine On

# Prevent rewrite loops once request is already inside /dist.
RewriteRule ^dist/ - [L]

# Always serve built entry file instead of Vite source index.html.
RewriteRule ^index\.html$ dist/index.html [L]

# Root domain opens the built app.
RewriteRule ^$ dist/index.html [L]

# Native deep-link association files must be served as static JSON, not SPA HTML.
RewriteRule ^\.well-known/(apple-app-site-association|assetlinks\.json)$ dist/.well-known/$1 [L,T=application/json]

# Public direct routes handled by the client router.
RewriteRule ^(privacy|terms|cookies|donacija-za-sos-djecije-selo)/?$ dist/index.html [L]

# Review route should redirect to the App Store.
RewriteRule ^review/?$ https://apps.apple.com/ba/app/snovi-fm/id6758638251 [R=302,L,NE]

# If requested path exists inside /dist, serve that file or directory.
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
RewriteRule ^(.+)$ dist/$1 [L]

# SPA fallback.
RewriteRule ^ dist/index.html [L]
